{
  "name": "be-trusted-registry",
  "version": "1.0.0",
  "scripts": {
    "start": "cd backend && node server.js",
    "build": "cd frontend && npm install && npm run build",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "monitor:prod": "bash scripts/monitor-prod.sh",
    "monitor:alert": "bash scripts/monitor-and-alert.sh",
    "monitor:cron:install": "bash scripts/install-monitor-cron.sh",
    "monitor:slack:activate": "bash scripts/install-monitor-cron.sh",
    "monitor:launchagent:install": "bash scripts/install-monitor-launchagent.sh",
    "monitor:launchagent:run": "launchctl kickstart -k gui/$(id -u)/com.be-registry.monitor",
    "alerts:slack:activate": "bash scripts/activate-slack-alerting.sh",
    "monitoring:stack:up": "docker compose -f monitoring/docker-compose.monitoring.yml up -d",
    "monitoring:stack:down": "docker compose -f monitoring/docker-compose.monitoring.yml down",
    "failover:auto": "bash scripts/auto-failover.sh",
    "stripe:validate:test": "STRIPE_CHECK_MODE=test bash scripts/stripe-live-validate.sh",
    "stripe:validate:live": "bash scripts/stripe-live-validate.sh",
    "ops:daily-report": "bash scripts/ops-daily-report.sh",
    "db:smoke": "node scripts/db-smoke.js",
    "db:backup": "bash scripts/db-backup.sh",
    "db:backup:cron:install": "bash scripts/install-backup-cron.sh",
    "db:backup:launchagent:install": "bash scripts/install-backup-launchagent.sh",
    "db:backup:launchagent:run": "bash scripts/run-backup-launchagent-now.sh",
    "db:audit:cycle": "bash scripts/db-audit-cycle.sh",
    "db:audit:launchagent:install": "bash scripts/install-audit-launchagent.sh",
    "db:audit:launchagent:run": "bash scripts/run-audit-launchagent-now.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "db:restore:dry-run": "bash scripts/db-restore-dry-run.sh"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
